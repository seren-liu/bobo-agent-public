POSTGRES_USER=bobo
POSTGRES_PASSWORD=bobo123
POSTGRES_DB=bobo

# Local host endpoints for running backend on your Mac
LOCAL_POSTGRES_PORT=15432
LOCAL_REDIS_PORT=16379
LOCAL_QDRANT_HTTP_PORT=16333
LOCAL_QDRANT_GRPC_PORT=16334

DATABASE_URL=postgresql://bobo:bobo123@127.0.0.1:15432/bobo
REDIS_URL=redis://127.0.0.1:16379/0
QDRANT_URL=http://127.0.0.1:16333

QWEN_API_KEY=
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
VISION_MODEL=qwen-vl-max
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_FALLBACK_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1024

COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-shanghai

JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE_HOURS=24
JWT_ALGORITHM=HS256

# Local frontend origin during dev
CORS_PROD_ORIGIN=http://localhost:5173

# backend host port when you run uvicorn locally
BACKEND_PORT=8000

# Optional: Alertmanager email notifications
ALERT_SMTP_SMARTHOST=smtp.example.com:587
ALERT_SMTP_USERNAME=
ALERT_SMTP_PASSWORD=
ALERT_EMAIL_FROM=bobo-alerts@example.com
ALERT_EMAIL_TO=you@example.com
