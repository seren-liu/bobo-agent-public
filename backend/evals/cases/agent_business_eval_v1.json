{
  "schema_version": "bobo-agent-business-eval.v1",
  "suite_name": "Bobo Agent Business Core Eval",
  "cases": [
    {
      "id": "chat.menu_fast_path_local",
      "kind": "chat",
      "user_id": "u-eval-menu-local",
      "thread_id": "eval-menu-local",
      "message": "给我推荐古茗的经典奶茶top3",
      "stubs": {
        "search_menu_results": [
          {
            "brand": "古茗",
            "query": "厚乳",
            "results": [
              {
                "id": "g-1",
                "brand": "古茗",
                "name": "经典奶香奶茶",
                "price": 12,
                "description": "经典奶香，口感顺滑",
                "score": 0.84
              }
            ]
          }
        ],
        "brand_coverage": true
      },
      "assertions": {
        "expected_status": 200,
        "event_types_include": ["meta", "tool_call", "tool_result", "text", "done"],
        "tools_include": ["search_menu"],
        "text_contains_all": ["古茗可以先看这几款奶茶", "经典奶香奶茶"],
        "call_expectations": {
          "search_menu_impl": 5,
          "stream_agent_events": 0
        }
      }
    },
