    {
      "id": "chat.graph_tool_path",
      "kind": "chat",
      "user_id": "u-eval-graph",
      "thread_id": "eval-graph",
      "message": "帮我推荐一杯清爽一点、预算 20 元以内的饮品",
      "stubs": {
        "graph_events": [
          {
            "event": "on_tool_start",
            "name": "search_menu",
            "run_id": "tool-1",
            "data": {
              "input": {
                "query": "清爽 20 元以内"
              }
            }
          },
          {
            "event": "on_tool_end",
            "name": "search_menu",
            "run_id": "tool-1",
            "data": {
              "output": {
                "results": [
                  {
                    "id": "m-1",
                    "brand": "喜茶",
                    "name": "多肉葡萄"
                  }
                ]
              }
            }
          },
          {
            "event": "on_chat_model_stream",
            "data": {
              "chunk": {
                "content": "可以先试试喜茶多肉葡萄，整体会比较清爽。"
              }
            }
          },
          {
            "event": "on_chat_model_end",
            "data": {
              "output": {
                "usage_metadata": {
                  "input_tokens": 24,
                  "output_tokens": 16
                }
              }
            }
          }
        ]
      },
      "assertions": {
        "expected_status": 200,
        "event_types_include": ["meta", "tool_call", "tool_result", "text", "done"],
        "tools_include": ["search_menu"],
        "text_contains_all": ["喜茶多肉葡萄", "清爽"],
        "call_expectations": {
          "stream_agent_events": 1
        }
      }
    },
