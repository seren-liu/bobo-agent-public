POSTGRES_USER=bobo
POSTGRES_PASSWORD=bobo123
POSTGRES_DB=bobo
DATABASE_URL=postgresql://bobo:bobo123@postgres:5432/bobo
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333

QWEN_API_KEY=
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
VISION_MODEL=qwen-vl-max
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_FALLBACK_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1024

COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-shanghai

JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE_HOURS=24
JWT_ALGORITHM=HS256

CORS_PROD_ORIGIN=https://bobo.yourdomain.com

BACKEND_PORT=8000

# Optional: manual backend image deploy via Tencent Container Registry (TCR)
TCR_REGISTRY=ccr.ccs.tencentyun.com
TCR_NAMESPACE=
TCR_REPOSITORY=backend
TCR_USERNAME=
TCR_PASSWORD=

# Optional: Alertmanager email notifications
ALERT_SMTP_SMARTHOST=smtp.example.com:587
ALERT_SMTP_USERNAME=
ALERT_SMTP_PASSWORD=
ALERT_EMAIL_FROM=bobo-alerts@example.com
ALERT_EMAIL_TO=you@example.com
